{
  "name": "mlform",
  "version": "0.1.3",
  "private": false,
  "description": "Composable form generation utilities for machine learning backend integration",
  "keywords": [
    "form-generator",
    "forms",
    "frontend",
    "library",
    "lit",
    "machine-learning",
    "ml",
    "models",
    "strategies",
    "typescript",
    "ui",
    "user-interface",
    "web-components",
    "zod"
  ],
  "homepage": "https://ulloasp.github.io/mlform/",
  "bugs": {
    "url": "https://github.com/UlloaSP/mlform/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Pablo Ulloa Santín",
    "email": "pablo.ulloa.santin@udc.es",
    "url": "https://github.com/UlloaSP"
  },
  "contributors": [
    {
      "name": "Pablo Ulloa Santín",
      "email": "pablo.ulloa.santin@udc.es",
      "url": "https://github.com/UlloaSP"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/UlloaSP/mlform.git"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/UlloaSP"
    }
  ],
  "files": [
    "dist/**"
  ],
  "type": "module",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/mlform.mjs"
    },
    "./kit": {
      "types": "./dist/types/kit/index.d.ts",
      "import": "./dist/mlform/kit.mjs"
    },
    "./engine": {
      "types": "./dist/types/engine/index.d.ts",
      "import": "./dist/mlform/engine.mjs"
    },
    "./primitives": {
      "types": "./dist/types/primitives/index.d.ts",
      "import": "./dist/mlform/primitives.mjs"
    },
    "./design-system": {
      "types": "./dist/types/design-system/index.d.ts",
      "import": "./dist/mlform/design-system.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "lint": "vp lint --fix",
    "type": "vp exec tsc -p tsconfig.json --noEmit",
    "build": "vp build",
    "test": "vp test run",
    "test:watch": "vp test",
    "coverage": "vp test run --coverage",
    "ci": "vp lint --fix && vp exec tsc -p tsconfig.json --noEmit && vp test run && vp build",
    "prepare": "vp config"
  },
  "dependencies": {
    "lit": "3.3.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.0.8",
    "jsdom": "^29.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-dts": "^4.5.4",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=24.9.0"
  },
  "packageManager": "npm@11.12.1"
}
